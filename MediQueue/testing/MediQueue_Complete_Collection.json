		{
			"name": "EDGE CASES: Blacklist",
			"item": [
				{
					"name": "EC1: Book Appointment for Edge Testing",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Appointment booked for edge testing', () => {",
									"    pm.response.to.have.status(201);",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('edgeTestAppointmentId', response.appointmentID);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{patientToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"doctorID\": {{testDoctorId}}, \"appointmentDate\": \"2026-05-20\", \"timeSlot\": \"11:00\"}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/appointments",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments"]
						}
					}
				},
				{
					"name": "EC2: Mark 1st Appointment Missed",
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/api/appointments/{{edgeTestAppointmentId}}/miss",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments", "{{edgeTestAppointmentId}}", "miss"]
						}
					}
				},
				{
					"name": "EC3: Verify Patient NOT Blacklisted (1 missed)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Patient not blacklisted after 1 missed', () => {",
									"    pm.response.to.have.status(200);",
									"    const response = pm.response.json();",
									"    pm.expect(response.IsBlacklisted).to.equal(0);",
									"    pm.expect(response.MissedVisits).to.equal(1);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{patientToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/api/patients/stats",
							"host": ["{{baseUrl}}"],
							"path": ["api", "patients", "stats"]
						}
					}
				},
				{
					"name": "EC4: Try Booking When Blacklisted",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Blacklisted patient booking rejected', () => {",
									"    pm.response.to.have.status(403);",
									"    const response = pm.response.json();",
									"    pm.expect(response.message).to.include('blacklisted');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{patientToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"doctorID\": {{testDoctorId}}, \"appointmentDate\": \"2026-05-25\", \"timeSlot\": \"14:00\"}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/appointments",
							"host": ["{{baseUrl}}"],
							"path": ["api", "appointments"]
						}
					}
				},
				{
					"name": "EC5: Try Walk-In When Blacklisted",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Blacklisted patient walk-in rejected', () => {",
									"    pm.response.to.have.status(403);",
									"    const response = pm.response.json();",
									"    pm.expect(response.message).to.include('blacklisted');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{adminToken}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"patientID\": {{testPatientId}}, \"doctorID\": {{testDoctorId}}, \"timeSlot\": \"15:00\"}"
